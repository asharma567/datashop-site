---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="text-xs uppercase tracking-widest text-neutral-500 mb-4">
      {entry.data.industry} · {entry.data.client}
    </div>
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight leading-tight">
      {entry.data.title}
    </h1>
    <p class="mt-6 text-xl text-neutral-600 leading-relaxed">{entry.data.summary}</p>

    {entry.data.metrics && entry.data.metrics.length > 0 && (
      <div class="mt-10 grid grid-cols-3 gap-6 border-y border-neutral-200 py-8">
        {entry.data.metrics.map((m) => (
          <div>
            <div class="text-3xl font-semibold tracking-tight">{m.value}</div>
            <div class="text-xs text-neutral-500 uppercase tracking-widest mt-1">{m.label}</div>
          </div>
        ))}
      </div>
    )}

    <div class="mt-12 space-y-10">
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500 mb-2">Problem</h2>
        <p class="text-lg leading-relaxed text-neutral-800">{entry.data.problem}</p>
      </section>
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500 mb-2">Approach</h2>
        <p class="text-lg leading-relaxed text-neutral-800">{entry.data.approach}</p>
      </section>
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500 mb-2">Outcome</h2>
        <p class="text-lg leading-relaxed text-neutral-800">{entry.data.outcome}</p>
      </section>
    </div>

    <div class="mt-12 prose prose-neutral max-w-none prose-headings:tracking-tight prose-h2:font-semibold prose-h2:text-2xl prose-h2:mt-10">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-neutral-200 flex items-center justify-between text-sm">
      <a href="/case-studies" class="text-neutral-600 hover:text-neutral-900">
        ← All case studies
      </a>
      <a
        href="/contact"
        class="bg-neutral-900 text-white px-5 py-2 rounded-full hover:bg-neutral-700 transition-colors font-medium"
      >
        Work with us
      </a>
    </div>
  </article>
</BaseLayout>
