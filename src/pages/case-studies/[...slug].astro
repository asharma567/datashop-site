---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="flex items-center gap-3 eyebrow">
      <span style="color: var(--color-accent)">{entry.data.industry}</span>
      <span aria-hidden="true" class="text-[var(--color-border-strong)]">·</span>
      <span>{entry.data.client}</span>
    </div>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-4xl md:text-6xl font-semibold tracking-[-0.02em] leading-[1.04]"
    >
      {entry.data.title}
    </h1>
    <p class="mt-8 text-xl text-[var(--color-fg-muted)] leading-relaxed">{entry.data.summary}</p>

    {entry.data.metrics && entry.data.metrics.length > 0 && (
      <div class="mt-12 grid grid-cols-3 gap-6 border-y border-[var(--color-border)] py-8">
        {entry.data.metrics.map((m, i) => {
          const accents = ['var(--color-accent)', 'var(--color-cool)', 'var(--color-accent-soft)'];
          return (
            <div>
              <div
                class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold tracking-tight"
                style={`color: ${accents[i % accents.length]}`}
              >
                {m.value}
              </div>
              <div class="eyebrow mt-2">{m.label}</div>
            </div>
          );
        })}
      </div>
    )}

    <div class="mt-14 space-y-10">
      <section>
        <h2 class="eyebrow" style="color: var(--color-accent)">The problem</h2>
        <p class="mt-3 text-lg leading-relaxed text-[var(--color-fg)]">{entry.data.problem}</p>
      </section>
      <section>
        <h2 class="eyebrow" style="color: var(--color-cool)">How we approached it</h2>
        <p class="mt-3 text-lg leading-relaxed text-[var(--color-fg)]">{entry.data.approach}</p>
      </section>
      <section>
        <h2 class="eyebrow" style="color: var(--color-accent-soft)">The outcome</h2>
        <p class="mt-3 text-lg leading-relaxed text-[var(--color-fg)]">{entry.data.outcome}</p>
      </section>
    </div>

    <div class="mt-14 prose prose-invert max-w-none">
      <Content />
    </div>

    <div
      class="mt-16 pt-8 border-t border-[var(--color-border)] flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-sm"
    >
      <a href="/case-studies" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]">
        ← All case studies
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-bg)] px-4 py-2 rounded-full hover:bg-[var(--color-fg)] transition-colors font-medium text-[14px]"
      >
        Work with us
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </article>
</BaseLayout>
