---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('podcasts');
  return episodes.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="font-[family-name:var(--font-mono)] text-sm text-[var(--color-fg-subtle)] mb-6">
      EPISODE {String(entry.data.episode).padStart(2, '0')}
    </div>
    <h1
      class="font-[family-name:var(--font-display)] text-4xl md:text-6xl font-semibold tracking-[-0.02em] leading-[1.04]"
    >
      {entry.data.title}
    </h1>
    {entry.data.guest && (
      <p class="mt-4 text-lg text-[var(--color-fg-muted)]">
        With {entry.data.guest}{entry.data.guestTitle ? `, ${entry.data.guestTitle}` : ''}
      </p>
    )}

    <div class="mt-8 flex flex-wrap gap-3">
      {entry.data.spotifyUrl && (
        <a
          href={entry.data.spotifyUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-4 py-2 rounded-full hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-sm"
        >
          Listen on Spotify →
        </a>
      )}
      {entry.data.appleUrl && (
        <a
          href={entry.data.appleUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-4 py-2 rounded-full hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-sm"
        >
          Apple Podcasts →
        </a>
      )}
      {entry.data.youtubeUrl && (
        <a
          href={entry.data.youtubeUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-4 py-2 rounded-full hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-sm"
        >
          Watch on YouTube →
        </a>
      )}
    </div>

    <p class="mt-10 text-xl text-[var(--color-fg-muted)] leading-relaxed">
      {entry.data.description}
    </p>

    <div class="mt-10 prose prose-invert max-w-none">
      <Content />
    </div>

    <div class="mt-14 pt-8 border-t border-[var(--color-border)]">
      <a href="/podcasts" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]">
        ← All episodes
      </a>
    </div>
  </article>
</BaseLayout>
