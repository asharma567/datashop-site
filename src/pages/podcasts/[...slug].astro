---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('podcasts');
  return episodes.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="text-sm font-mono text-neutral-500 mb-4">
      Episode {String(entry.data.episode).padStart(2, '0')}
    </div>
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight leading-tight">
      {entry.data.title}
    </h1>
    {entry.data.guest && (
      <p class="mt-4 text-lg text-neutral-600">
        With {entry.data.guest}{entry.data.guestTitle ? `, ${entry.data.guestTitle}` : ''}
      </p>
    )}

    <div class="mt-8 flex flex-wrap gap-3">
      {entry.data.spotifyUrl && (
        <a
          href={entry.data.spotifyUrl}
          target="_blank"
          rel="noopener"
          class="border border-neutral-300 px-4 py-2 rounded-full text-sm hover:bg-neutral-100"
        >
          Listen on Spotify
        </a>
      )}
      {entry.data.appleUrl && (
        <a
          href={entry.data.appleUrl}
          target="_blank"
          rel="noopener"
          class="border border-neutral-300 px-4 py-2 rounded-full text-sm hover:bg-neutral-100"
        >
          Apple Podcasts
        </a>
      )}
      {entry.data.youtubeUrl && (
        <a
          href={entry.data.youtubeUrl}
          target="_blank"
          rel="noopener"
          class="border border-neutral-300 px-4 py-2 rounded-full text-sm hover:bg-neutral-100"
        >
          YouTube
        </a>
      )}
    </div>

    <p class="mt-10 text-xl text-neutral-700 leading-relaxed">{entry.data.description}</p>

    <div class="mt-10 prose prose-neutral max-w-none prose-headings:tracking-tight prose-h2:text-2xl prose-h2:font-semibold prose-h2:mt-10">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-neutral-200">
      <a href="/podcasts" class="text-sm text-neutral-600 hover:text-neutral-900">
        ← All episodes
      </a>
    </div>
  </article>
</BaseLayout>
