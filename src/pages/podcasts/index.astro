---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const episodes = (await getCollection('podcasts')).sort((a, b) => b.data.episode - a.data.episode);
---

<BaseLayout title="Podcast">
  <section class="mx-auto max-w-4xl px-6 pt-20 pb-12">
    <p class="text-sm font-medium text-neutral-500 uppercase tracking-widest mb-4">Podcast</p>
    <h1 class="text-5xl font-semibold tracking-tight">Conversations on applied AI.</h1>
    <p class="mt-6 text-xl text-neutral-600 max-w-2xl">
      Long-form conversations with operators, researchers, and founders shipping AI in the real world.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-24">
    {episodes.length === 0 ? (
      <p class="text-neutral-500 italic">Episodes coming soon.</p>
    ) : (
      <ol class="divide-y divide-neutral-200">
        {episodes.map((ep) => (
          <li class="py-8 flex flex-col md:flex-row md:items-start gap-6">
            <div class="md:w-20 shrink-0 text-sm font-mono text-neutral-500">
              Ep. {String(ep.data.episode).padStart(2, '0')}
            </div>
            <div class="flex-1">
              <a
                href={`/podcasts/${ep.id}`}
                class="block group"
              >
                <h2 class="text-2xl font-semibold tracking-tight group-hover:underline">
                  {ep.data.title}
                </h2>
              </a>
              {ep.data.guest && (
                <p class="mt-1 text-sm text-neutral-500">
                  With {ep.data.guest}{ep.data.guestTitle ? `, ${ep.data.guestTitle}` : ''}
                </p>
              )}
              <p class="mt-3 text-neutral-700 leading-relaxed">{ep.data.description}</p>
              <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
                {ep.data.spotifyUrl && (
                  <a href={ep.data.spotifyUrl} target="_blank" rel="noopener" class="text-neutral-700 hover:text-neutral-900 underline">
                    Spotify
                  </a>
                )}
                {ep.data.appleUrl && (
                  <a href={ep.data.appleUrl} target="_blank" rel="noopener" class="text-neutral-700 hover:text-neutral-900 underline">
                    Apple Podcasts
                  </a>
                )}
                {ep.data.youtubeUrl && (
                  <a href={ep.data.youtubeUrl} target="_blank" rel="noopener" class="text-neutral-700 hover:text-neutral-900 underline">
                    YouTube
                  </a>
                )}
                {ep.data.duration && <span class="text-neutral-500">{ep.data.duration}</span>}
              </div>
            </div>
          </li>
        ))}
      </ol>
    )}
  </section>
</BaseLayout>
