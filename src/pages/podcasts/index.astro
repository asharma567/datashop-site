---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';

const episodes = (await getCollection('podcasts')).sort(
  (a, b) => b.data.episode - a.data.episode
);

const dateFormat = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title="Podcast">
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <p class="eyebrow">Podcast</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Conversations on
      <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">
        applied AI
      </span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
      Long-form conversations with operators, researchers, and founders shipping AI in the real
      world. Watch the episodes below, or subscribe on
      <a
        href="https://www.youtube.com/@datashop-ai"
        target="_blank"
        rel="noopener"
        class="underline hover:text-[var(--color-fg)]"
      >YouTube</a>.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    {episodes.length === 0 ? (
      <p class="text-[var(--color-fg-muted)] italic">Episodes coming soon.</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-8 md:gap-10">
        {episodes.map((ep) => (
          <article class="flex flex-col">
            {ep.data.videoId && (
              <YouTubeEmbed videoId={ep.data.videoId} title={ep.data.title} />
            )}
            <div class="mt-5 flex items-center gap-3">
              <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-fg-subtle)]">
                EP {String(ep.data.episode).padStart(2, '0')}
              </span>
              <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-fg-subtle)]">
                {dateFormat.format(ep.data.published)}
              </span>
              {ep.data.duration && (
                <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-fg-subtle)]">
                  {ep.data.duration}
                </span>
              )}
            </div>
            <a href={`/podcasts/${ep.id}`} class="mt-2 group">
              <h2
                class="font-[family-name:var(--font-display)] text-2xl font-semibold tracking-tight text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors"
              >
                {ep.data.title}
              </h2>
            </a>
            {ep.data.guest && (
              <p class="mt-1 text-sm text-[var(--color-fg-muted)]">
                With {ep.data.guest}{ep.data.guestTitle ? `, ${ep.data.guestTitle}` : ''}
              </p>
            )}
            <p class="mt-4 text-[var(--color-fg-muted)] leading-relaxed">
              {ep.data.description}
            </p>
            <a
              href={`/podcasts/${ep.id}`}
              class="mt-5 inline-flex items-center gap-2 text-sm text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors self-start"
            >
              Show notes
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
