---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  services.map(async (s) => ({ entry: s, ...(await render(s)) }))
);
---

<BaseLayout title="What we do">
  <section class="mx-auto max-w-4xl px-6 pt-20 pb-14">
    <p class="eyebrow">What we do</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Two shapes of <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">engagement</span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
      We're deliberate about scope. These are the two engagements we've done enough times to
      know we can deliver — and we won't pretend otherwise.
    </p>
  </section>

  {rendered.map(({ entry, Content }, i) => (
    <section
      id={entry.id}
      class="mx-auto max-w-4xl px-6 py-16 border-t border-[var(--color-border)]"
    >
      <div
        class="eyebrow"
        style={`color: ${i === 0 ? 'var(--color-accent)' : 'var(--color-cool)'}`}
      >
        {i === 0 ? '01 / Org-wide transformation' : '02 / MVP → production'}
      </div>
      <h2
        class="mt-4 font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold tracking-[-0.01em]"
      >
        {entry.data.title}
      </h2>
      <p class="mt-5 text-lg text-[var(--color-fg-muted)] leading-relaxed">
        {entry.data.tagline}
      </p>
      <div class="mt-10 prose prose-invert max-w-none">
        <Content />
      </div>
    </section>
  ))}

  <section class="mx-auto max-w-4xl px-6 py-24 border-t border-[var(--color-border)]">
    <a
      href="/contact"
      class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-bg)] px-5 py-3 rounded-full hover:bg-[var(--color-fg)] transition-colors font-medium text-[14px]"
    >
      Start a conversation
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
