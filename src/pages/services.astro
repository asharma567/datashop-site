---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientReel from '../components/ClientReel.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="What we do">
  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-6 pt-20 pb-14">
    <p class="eyebrow">What we do</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Two shapes of
      <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">
        engagement
      </span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
      We're deliberate about scope. These are the two engagements we've done enough times to know
      we can deliver.
    </p>
  </section>

  <!-- Service cards -->
  <section class="mx-auto max-w-6xl px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-5">
      {services.map((service, i) => {
        const icon = i === 0 ? '/icons/org-wide.png' : '/icons/mvp-scale.png';
        const eyebrow = i === 0 ? '01 / Org-wide' : '02 / MVP → scale';
        const accent = i === 0 ? 'var(--color-accent)' : 'var(--color-fg-muted)';
        return (
          <article
            id={service.id}
            class="p-8 md:p-10 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elev)]"
          >
            <img
              src={icon}
              alt=""
              loading="lazy"
              decoding="async"
              class="h-20 w-20 md:h-24 md:w-24 -ml-2"
              aria-hidden="true"
            />
            <div class="mt-5 eyebrow" style={`color: ${accent}`}>{eyebrow}</div>
            <h2
              class="mt-3 font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold tracking-tight text-[var(--color-fg)]"
            >
              {service.data.title}
            </h2>
            <p class="mt-3 text-[var(--color-fg-muted)] leading-relaxed">{service.data.tagline}</p>

            {service.data.bullets && service.data.bullets.length > 0 && (
              <ul class="mt-6 space-y-3">
                {service.data.bullets.map((b) => (
                  <li class="flex gap-3 text-[15px] text-[var(--color-fg)] leading-relaxed">
                    <span
                      class="mt-2 shrink-0 h-[5px] w-[5px] rounded-full"
                      style={`background: ${accent}`}
                      aria-hidden="true"
                    ></span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            )}

            {service.data.audience && (
              <p class="mt-8 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-fg-muted)] leading-relaxed">
                <span class="eyebrow mr-2">Who this is for</span>
                {service.data.audience}
              </p>
            )}
          </article>
        );
      })}
    </div>
  </section>

  <!-- Client reel -->
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl px-6 pt-10">
      <p class="eyebrow">Trusted to ship production systems</p>
    </div>
    <ClientReel />
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-6 pb-24 pt-20 border-t border-[var(--color-border)]">
    <div class="bg-[var(--color-bg-elev)] border border-[var(--color-border)] rounded-[var(--radius-xl)] p-10 md:p-16">
      <div class="grid md:grid-cols-[1.3fr_1fr] gap-10 items-end">
        <div>
          <p class="eyebrow">Engagement fit</p>
          <h2
            class="mt-5 font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold tracking-[-0.025em]"
          >
            Think one of these is your shape?
          </h2>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-[var(--color-fg-muted)] leading-relaxed">
            We work with a small number of teams each quarter. Send us the situation and what
            "great" would look like — we'll tell you honestly whether it fits.
          </p>
          <a
            href="/contact"
            class="self-start inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3.5 rounded-lg hover:bg-[var(--color-accent-soft)] transition-colors font-medium text-[15px]"
          >
            Start a conversation
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
