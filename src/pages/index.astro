---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientReel from '../components/ClientReel.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const featuredStudies = (await getCollection('caseStudies'))
  .filter((s) => s.data.featured)
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="grain relative mx-auto max-w-6xl px-6 pt-20 pb-24">
    <p class="eyebrow">AI &nbsp;·&nbsp; Data engineering &nbsp;·&nbsp; Crypto</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-[44px] md:text-[76px] font-semibold tracking-[-0.02em] leading-[1.02] text-[var(--color-fg)] max-w-4xl"
    >
      Artificial intelligence.
      <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">
        Real business results.
      </span>
    </h1>
    <p
      class="mt-8 text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed max-w-2xl"
    >
      We're a specialized engineering firm. Two things we do well: transform how an entire
      organization operates around AI, and take a working MVP and turn it into a production
      system that scales. Quietly. At latency that doesn't embarrass you.
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3 rounded-full hover:bg-[var(--color-accent-soft)] transition-colors font-medium text-[14px]"
      >
        Start a conversation
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 border border-[var(--color-border-strong)] text-[var(--color-fg)] px-5 py-3 rounded-full hover:border-[var(--color-fg)] transition-colors font-medium text-[14px]"
      >
        See our work
      </a>
    </div>

  </section>

  <!-- Client reel — escapes the page max-width to run edge-to-edge -->
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl px-6 pt-10">
      <p class="eyebrow">Trusted to ship production systems</p>
    </div>
    <ClientReel />
  </section>

  <!-- Services -->
  <section class="mx-auto max-w-6xl px-6 py-24 border-t border-[var(--color-border)]">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="eyebrow">What we do</p>
        <h2
          class="mt-4 font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold tracking-[-0.01em] text-[var(--color-fg)] max-w-2xl"
        >
          Two things, done thoroughly.
        </h2>
      </div>
      <a
        href="/services"
        class="hidden md:inline-block text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"
      >
        Full capabilities →
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-5">
      {services.map((service, i) => (
        <a
          href={`/services#${service.id}`}
          class="brackets group block p-8 md:p-10 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] hover:bg-[var(--color-bg-muted)] transition-colors"
        >
          <div class="eyebrow" style={`color: ${i === 0 ? 'var(--color-accent)' : 'var(--color-cool)'}`}>
            {i === 0 ? '01 / Org-wide' : '02 / MVP → scale'}
          </div>
          <h3
            class="mt-4 font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold tracking-tight text-[var(--color-fg)]"
          >
            {service.data.title}
          </h3>
          <p class="mt-4 text-[var(--color-fg-muted)] leading-relaxed">{service.data.tagline}</p>
          <span class="inline-flex items-center gap-2 mt-6 text-sm text-[var(--color-fg)]">
            Learn more
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured case studies -->
  {featuredStudies.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-24 border-t border-[var(--color-border)]">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="eyebrow">Recent work</p>
          <h2
            class="mt-4 font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold tracking-[-0.01em] max-w-2xl"
          >
            Shipped in weeks, not quarters.
          </h2>
        </div>
        <a
          href="/case-studies"
          class="hidden md:inline-block text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"
        >
          All case studies →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {featuredStudies.map((study, i) => {
          const accents = ['var(--color-accent)', 'var(--color-cool)', 'var(--color-accent-soft)'];
          return (
            <a
              href={`/case-studies/${study.id}`}
              class="brackets group block p-7 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] hover:bg-[var(--color-bg-muted)] transition-colors"
            >
              <div class="flex items-center justify-between mb-4">
                <span class="eyebrow" style={`color: ${accents[i % accents.length]}`}>{study.data.industry}</span>
                <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-fg-subtle)]">{study.data.client}</span>
              </div>
              <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold tracking-tight text-[var(--color-fg)]">
                {study.data.title}
              </h3>
              <p class="mt-3 text-sm text-[var(--color-fg-muted)] leading-relaxed line-clamp-4">
                {study.data.summary}
              </p>
              {study.data.metrics && study.data.metrics.length > 0 && (
                <div class="mt-6 pt-5 border-t border-[var(--color-border)] flex gap-5">
                  {study.data.metrics.slice(0, 2).map((m) => (
                    <div>
                      <div class="font-[family-name:var(--font-display)] text-lg font-semibold text-[var(--color-fg)]">
                        {m.value}
                      </div>
                      <div class="eyebrow mt-1">{m.label}</div>
                    </div>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Pullquote / voice block -->
  <section class="mx-auto max-w-4xl px-6 py-24 border-t border-[var(--color-border)] text-center">
    <p class="eyebrow">What we keep saying</p>
    <blockquote
      class="mt-6 font-[family-name:var(--font-editorial)] italic text-3xl md:text-5xl font-normal leading-[1.15] tracking-tight text-[var(--color-fg)]"
    >
      "Most teams don't need another AI pilot. They need the two or three things that actually
      move the business — and the discipline to see them through."
    </blockquote>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="brackets bg-[var(--color-bg-elev)] border border-[var(--color-border)] rounded-[var(--radius-xl)] p-10 md:p-16">
      <div class="grid md:grid-cols-[1.3fr_1fr] gap-10 items-end">
        <div>
          <p class="eyebrow" style="color: var(--color-accent)">Get in touch</p>
          <h2
            class="mt-5 font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold tracking-[-0.01em]"
          >
            Have an MVP you need to scale, or an organization ready to move on AI?
          </h2>
        </div>
        <div class="flex flex-col gap-4">
          <p class="text-[var(--color-fg-muted)] leading-relaxed">
            We partner with a small number of teams each quarter. Tell us what you're working on
            and what "great" would look like.
          </p>
          <a
            href="/contact"
            class="self-start inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3 rounded-full hover:bg-[var(--color-accent-soft)] transition-colors font-medium text-[14px]"
          >
            Start a conversation
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
