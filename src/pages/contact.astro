---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-2xl px-6 pt-20 pb-24">
    <p class="eyebrow">Contact</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Let's <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">talk</span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Fastest way to reach us is email. Tell us what you're working on, where you're stuck, and
      what "great" would look like for you.
    </p>

    <div class="brackets mt-12 p-8 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elev)]">
      <div class="eyebrow" style="color: var(--color-accent)">Email</div>
      <a
        href={`mailto:${SITE.email}?subject=New%20engagement%20enquiry`}
        class="block mt-3 font-[family-name:var(--font-display)] text-2xl md:text-3xl font-medium text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors"
      >
        {SITE.email}
      </a>
      <p class="mt-4 text-sm text-[var(--color-fg-muted)]">
        We read everything and reply within two business days.
      </p>
    </div>

    <div class="mt-10">
      <p class="eyebrow mb-4">Things that help us respond quickly</p>
      <ul class="space-y-3 text-[var(--color-fg-muted)]">
        <li class="flex gap-3">
          <span class="text-[var(--color-accent)] mt-1" aria-hidden="true">→</span>
          <span>Company, your role, a one-line description of the business</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-mint)] mt-1" aria-hidden="true">→</span>
          <span>Which of the two engagements you think we'd work on together</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-cyan)] mt-1" aria-hidden="true">→</span>
          <span>What you've already tried and what surprised you about it</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-peach)] mt-1" aria-hidden="true">→</span>
          <span>Timeline and constraints — budget, regulatory, political, whatever</span>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
