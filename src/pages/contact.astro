---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-2xl px-6 pt-20 pb-24">
    <p class="eyebrow">Contact</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Let's <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">talk</span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Tell us what you're working on, where you're stuck, and what "great" would look like for
      you. We read everything and reply within two business days.
    </p>

    <form id="contact-form" class="mt-12 space-y-5" autocomplete="on" novalidate>
      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="eyebrow block mb-2">Your name</span>
          <input
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="Ada Lovelace"
          />
        </label>
        <label class="block">
          <span class="eyebrow block mb-2">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="you@company.com"
          />
        </label>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="eyebrow block mb-2">Company</span>
          <input
            name="company"
            autocomplete="organization"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="Company"
          />
        </label>
        <label class="block">
          <span class="eyebrow block mb-2">I think we'd work on</span>
          <select
            name="engagement"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors appearance-none"
          >
            <option value="Not sure yet">Not sure yet</option>
            <option value="Org-wide AI transformation">Org-wide AI transformation</option>
            <option value="MVP to production scale">MVP to production scale</option>
            <option value="Something else">Something else</option>
          </select>
        </label>
      </div>

      <label class="block">
        <span class="eyebrow block mb-2">What you're working on</span>
        <textarea
          name="message"
          required
          rows="6"
          class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors resize-y min-h-[140px]"
          placeholder="The business, where you're stuck, what you've already tried, timeline and any constraints."
        ></textarea>
      </label>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-2">
        <button
          type="submit"
          class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3 rounded-full hover:bg-[var(--color-accent-soft)] transition-colors font-medium text-[14px]"
        >
          Send
          <span aria-hidden="true">→</span>
        </button>
        <p class="text-xs text-[var(--color-fg-subtle)]">
          Submitting opens your default mail client addressed to
          <a href={`mailto:${SITE.email}`} class="underline hover:text-[var(--color-fg)]">{SITE.email}</a>.
        </p>
      </div>
    </form>

    <div class="mt-14 pt-10 border-t border-[var(--color-border)]">
      <p class="eyebrow mb-4">Prefer just to email?</p>
      <a
        href={`mailto:${SITE.email}?subject=New%20engagement%20enquiry`}
        class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-medium text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors"
      >
        {SITE.email} →
      </a>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ email: SITE.email }}>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = /** @type {HTMLFormElement} */ (form);
      const d = new FormData(f);
      const name = (d.get('name') || '').toString().trim();
      const mail = (d.get('email') || '').toString().trim();
      const company = (d.get('company') || '').toString().trim();
      const engagement = (d.get('engagement') || '').toString().trim();
      const message = (d.get('message') || '').toString().trim();

      if (!name || !mail || !message) {
        alert('Please fill in your name, email, and a short message.');
        return;
      }

      const subject = `New engagement enquiry — ${name}${company ? ' · ' + company : ''}`;
      const bodyLines = [
        `From: ${name} <${mail}>`,
        company ? `Company: ${company}` : null,
        engagement ? `Interested in: ${engagement}` : null,
        '',
        message,
        '',
        '— sent via datashop.ai contact form',
      ].filter((l) => l !== null);

      const href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(
        bodyLines.join('\n')
      )}`;
      window.location.href = href;
    });
  }
</script>
