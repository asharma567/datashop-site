---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-2xl px-6 pt-20 pb-24">
    <p class="eyebrow">Contact</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Let's <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">talk</span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Tell us what you're working on, where you're stuck, and what "great" would look like for
      you. We read everything and reply within two business days.
    </p>

    <form id="contact-form" class="mt-12 space-y-5" autocomplete="on" novalidate>
      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="eyebrow block mb-2">Your name</span>
          <input
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="Ada Lovelace"
          />
        </label>
        <label class="block">
          <span class="eyebrow block mb-2">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="you@company.com"
          />
        </label>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <label class="block">
          <span class="eyebrow block mb-2">Company</span>
          <input
            name="company"
            autocomplete="organization"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors"
            placeholder="Company"
          />
        </label>
        <label class="block">
          <span class="eyebrow block mb-2">I think we'd work on</span>
          <select
            name="engagement"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors appearance-none"
          >
            <option value="Not sure yet">Not sure yet</option>
            <option value="Org-wide AI transformation">Org-wide AI transformation</option>
            <option value="MVP to production scale">MVP to production scale</option>
            <option value="Something else">Something else</option>
          </select>
        </label>
      </div>

      <label class="block">
        <span class="eyebrow block mb-2">What you're working on</span>
        <textarea
          name="message"
          required
          rows="6"
          class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-fg-subtle)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/30 transition-colors resize-y min-h-[140px]"
          placeholder="The business, where you're stuck, what you've already tried, timeline and any constraints."
        ></textarea>
      </label>

      <input type="text" name="company_website" tabindex="-1" autocomplete="off" aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 opacity-0" />

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-2">
        <button
          id="contact-submit"
          type="submit"
          class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3.5 rounded-lg hover:bg-[var(--color-accent-soft)] transition-colors font-medium text-[15px] disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span data-label-default>Send</span>
          <span data-label-sending class="hidden">Sending…</span>
          <span aria-hidden="true">→</span>
        </button>
        <p class="text-xs text-[var(--color-fg-subtle)]">
          Submissions go straight to our team. We'll reply from a real person within two business days.
        </p>
      </div>

      <div id="contact-status" class="hidden" role="status" aria-live="polite"></div>
    </form>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-status');
  const submit = document.getElementById('contact-submit');
  const labelDefault = submit?.querySelector('[data-label-default]');
  const labelSending = submit?.querySelector('[data-label-sending]');

  function setStatus(kind, text) {
    if (!status) return;
    status.classList.remove('hidden');
    status.className = 'mt-2 text-sm rounded-[var(--radius-md)] px-4 py-3 ' +
      (kind === 'ok'
        ? 'bg-[var(--color-accent)]/15 text-[var(--color-accent)] border border-[var(--color-accent)]/30'
        : 'bg-red-500/10 text-red-300 border border-red-500/30');
    status.textContent = text;
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = /** @type {HTMLFormElement} */ (form);
      const d = new FormData(f);
      const payload = {
        name: (d.get('name') || '').toString().trim(),
        email: (d.get('email') || '').toString().trim(),
        company: (d.get('company') || '').toString().trim(),
        engagement: (d.get('engagement') || '').toString().trim(),
        message: (d.get('message') || '').toString().trim(),
        company_website: (d.get('company_website') || '').toString().trim(),
      };

      if (!payload.name || !payload.email || !payload.message) {
        setStatus('err', 'Please fill in your name, email, and a short message.');
        return;
      }

      submit?.setAttribute('disabled', 'true');
      labelDefault?.classList.add('hidden');
      labelSending?.classList.remove('hidden');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body.error || 'Send failed');
        }
        f.reset();
        setStatus('ok', "Thanks — your message is on its way. We'll be in touch within two business days.");
      } catch (err) {
        setStatus('err', 'Something went wrong sending your message. Please try again in a moment.');
      } finally {
        submit?.removeAttribute('disabled');
        labelDefault?.classList.remove('hidden');
        labelSending?.classList.add('hidden');
      }
    });
  }
</script>
