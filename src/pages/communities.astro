---
import BaseLayout from '../layouts/BaseLayout.astro';

const partnerships = [
  {
    name: 'AI Council 2026',
    tagline: 'The AI conference for humans who ship.',
    meta: 'May 12–14, 2026 · San Francisco',
    href: 'https://aicouncil.com/sf-2026',
    role: 'Partner',
  },
];
---

<BaseLayout title="Communities & partnerships">
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <p class="eyebrow">Communities & partnerships</p>
    <h1
      class="mt-6 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-semibold tracking-[-0.02em] leading-[1.02]"
    >
      Where we
      <span class="font-[family-name:var(--font-editorial)] italic font-normal text-[var(--color-accent)]">
        show up
      </span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
      Conferences, communities, and partner organizations we're part of.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {partnerships.map((p) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group block p-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elev)] hover:bg-[var(--color-bg-muted)] hover:border-[var(--color-border-strong)] transition-colors"
        >
          <div class="eyebrow">{p.role}</div>
          <h2
            class="mt-3 font-[family-name:var(--font-display)] text-xl font-semibold tracking-[-0.02em] text-[var(--color-fg)]"
          >
            {p.name}
          </h2>
          <p class="mt-2 text-[var(--color-fg-muted)] leading-relaxed text-sm">{p.tagline}</p>
          <div class="mt-5 pt-4 border-t border-[var(--color-border)] flex items-center justify-between">
            <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-fg-subtle)]">
              {p.meta}
            </span>
            <span aria-hidden="true" class="text-[var(--color-fg-muted)] transition-transform group-hover:translate-x-1">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
