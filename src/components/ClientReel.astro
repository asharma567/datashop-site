---
import { CLIENTS } from '../consts';

const rail = [...CLIENTS, ...CLIENTS];
---

<section aria-label="Clients we've shipped production systems for" class="reel relative overflow-hidden mask">
  <ul class="track flex items-center gap-6 py-8 will-change-transform">
    {rail.map((c, i) => (
      <li
        class="shrink-0 flex items-center justify-center h-20 w-48 px-6"
        aria-hidden={i >= CLIENTS.length ? 'true' : undefined}
      >
        {c.logo ? (
          <img
            src={c.logo}
            alt={c.label}
            loading="lazy"
            decoding="async"
            class:list={[
              'max-h-10 max-w-full object-contain opacity-80 hover:opacity-100 transition-opacity',
              c.invert && 'logo-invert',
            ]}
          />
        ) : (
          <span
            class="font-[family-name:var(--font-display)] font-bold text-lg tracking-tight text-[var(--color-fg-muted)]"
          >
            {c.label}
          </span>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  .logo-invert {
    filter: invert(1);
  }

  .reel {
    --mask: linear-gradient(
      to right,
      transparent 0,
      black 3%,
      black 97%,
      transparent 100%
    );
    -webkit-mask-image: var(--mask);
            mask-image: var(--mask);
  }

  .track {
    width: max-content;
    animation: reel 54s linear infinite;
  }
  .reel:hover .track,
  .reel:focus-within .track {
    animation-play-state: paused;
  }

  @keyframes reel {
    from {
      transform: translateX(0);
    }
    to {
      /* Duplicated rail → seamless loop at -50% */
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>
