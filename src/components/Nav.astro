---
import { SITE, NAV } from '../consts';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-bg)_92%,transparent)] backdrop-blur-md">
  <nav class="mx-auto max-w-6xl px-6 py-5 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Datashop home">
      <img
        src="/brand/logo-mark.png"
        alt=""
        aria-hidden="true"
        width="698"
        height="950"
        class="h-7 w-auto transition-transform group-hover:scale-105"
      />
      <span
        class="font-[family-name:var(--font-display)] font-semibold tracking-tight text-[15px] text-[var(--color-fg)]"
      >
        {SITE.name}
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8 text-[13px]">
      {NAV.filter((n) => n.href !== '/').map((n) => (
        <li>
          <a
            href={n.href}
            class:list={[
              'transition-colors',
              isActive(n.href)
                ? 'text-[var(--color-fg)]'
                : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]',
            ]}
          >
            {n.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="/contact"
        class="hidden sm:inline-flex group items-center gap-2 text-[13px] border border-[var(--color-border-strong)] text-[var(--color-fg)] px-4 py-2.5 rounded-lg hover:border-[var(--color-fg)] transition-colors"
      >
        <span>Start a conversation</span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-nav-toggle"
        type="button"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="Open menu"
        class="md:hidden inline-flex items-center justify-center h-11 w-11 rounded-lg border border-[var(--color-border-strong)] text-[var(--color-fg)] hover:border-[var(--color-fg)] transition-colors"
      >
        <svg id="mobile-nav-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="7" x2="21" y2="7"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="17" x2="21" y2="17"></line>
        </svg>
        <svg id="mobile-nav-icon-close" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    hidden
    class="md:hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]"
  >
    <ul class="mx-auto max-w-6xl px-6 py-4 flex flex-col gap-3 text-[15px]">
      {NAV.filter((n) => n.href !== '/').map((n) => (
        <li>
          <a
            href={n.href}
            data-mobile-nav-link
            class:list={[
              'block py-2 transition-colors',
              isActive(n.href)
                ? 'text-[var(--color-fg)]'
                : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]',
            ]}
          >
            {n.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          data-mobile-nav-link
          class="inline-flex items-center gap-2 bg-[var(--color-accent)] text-[var(--color-on-accent)] px-5 py-3.5 rounded-lg transition-colors font-medium text-[14px]"
        >
          Start a conversation
          <span aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById('mobile-nav-toggle');
    const panel = document.getElementById('mobile-nav');
    const iconOpen = document.getElementById('mobile-nav-icon-open');
    const iconClose = document.getElementById('mobile-nav-icon-close');
    if (!btn || !panel || !iconOpen || !iconClose) return;

    const setOpen = (open) => {
      if (open) {
        panel.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', 'Close menu');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
      } else {
        panel.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Open menu');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }
    };

    btn.addEventListener('click', () => {
      setOpen(panel.hasAttribute('hidden'));
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hasAttribute('hidden')) {
        setOpen(false);
        btn.focus();
      }
    });

    // Close on link tap
    panel.querySelectorAll('[data-mobile-nav-link]').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (panel.hasAttribute('hidden')) return;
      if (panel.contains(e.target) || btn.contains(e.target)) return;
      setOpen(false);
    });
  })();
</script>
