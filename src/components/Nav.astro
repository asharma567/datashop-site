---
import { SITE, NAV } from '../consts';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="border-b border-neutral-200 bg-white/80 backdrop-blur sticky top-0 z-50">
  <nav class="mx-auto max-w-6xl px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-lg text-neutral-900">
      {SITE.name}
    </a>
    <ul class="hidden md:flex items-center gap-8 text-sm">
      {NAV.filter((n) => n.href !== '/').map((n) => (
        <li>
          <a
            href={n.href}
            class:list={[
              'transition-colors',
              isActive(n.href)
                ? 'text-neutral-900 font-medium'
                : 'text-neutral-600 hover:text-neutral-900',
            ]}
          >
            {n.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="/contact"
      class="text-sm bg-neutral-900 text-white px-4 py-2 rounded-full hover:bg-neutral-700 transition-colors"
    >
      Start a conversation
    </a>
  </nav>
</header>
