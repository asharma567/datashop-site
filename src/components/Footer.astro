---
import { SITE, NAV } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-24">
  <div class="mx-auto max-w-6xl px-6 py-14 grid md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-2">
        <span
          class="inline-block h-2 w-2 rounded-full bg-[var(--color-accent)]"
          aria-hidden="true"
        ></span>
        <span
          class="font-[family-name:var(--font-display)] font-semibold tracking-tight text-[var(--color-fg)]"
        >
          {SITE.name}
        </span>
      </div>
      <p class="mt-3 max-w-xs text-sm text-[var(--color-fg-muted)] leading-relaxed">
        {SITE.description}
      </p>
    </div>

    <div>
      <div class="eyebrow mb-4">Navigate</div>
      <ul class="space-y-2 text-sm">
        {NAV.filter((n) => n.href !== '/').map((n) => (
          <li>
            <a href={n.href} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]">
              {n.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <div class="eyebrow mb-4">Contact</div>
      <a
        href={`mailto:${SITE.email}`}
        class="block text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors font-[family-name:var(--font-display)] text-lg"
      >
        {SITE.email}
      </a>
      <p class="mt-4 text-xs text-[var(--color-fg-subtle)]">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
