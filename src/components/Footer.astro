---
import { SITE, NAV } from '../consts';
const year = new Date().getFullYear();
const social = [
  { label: 'YouTube', href: 'https://www.youtube.com/@datashop' },
];
---

<footer class="border-t border-[var(--color-border)] mt-24">
  <div class="mx-auto max-w-6xl px-6 py-14 grid md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-2.5">
        <img
          src="/brand/logo-mark.png"
          alt=""
          aria-hidden="true"
          width="698"
          height="950"
          class="h-8 w-auto"
        />
        <span
          class="font-[family-name:var(--font-display)] font-semibold tracking-tight text-[var(--color-fg)]"
        >
          {SITE.name}
        </span>
      </div>
    </div>

    <div>
      <div class="eyebrow mb-4">Navigate</div>
      <ul class="space-y-2 text-sm">
        {NAV.filter((n) => n.href !== '/').map((n) => (
          <li>
            <a href={n.href} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]">
              {n.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <div class="eyebrow mb-4">Get in touch</div>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 text-[var(--color-fg)] hover:text-[var(--color-fg-muted)] transition-colors font-[family-name:var(--font-display)] text-lg group"
      >
        <span>Start a conversation</span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>
      <ul class="mt-5 flex gap-4 text-sm">
        {social.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]">
              {s.label}
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-5 text-xs text-[var(--color-fg-subtle)]">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
